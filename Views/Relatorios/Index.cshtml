@{ ViewData["Title"] = "Relatórios"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i>Relatórios</h5>
</div>

<div class="row g-4">
    <!-- Exportar PDF -->
    <div class="col-12 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-danger-subtle rounded-3 p-3">
                        <i class="bi bi-file-earmark-pdf-fill text-danger fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Relatório Mensal em PDF</h6>
                        <small class="text-muted">Exporta todos os lançamentos do mês com resumo financeiro</small>
                    </div>
                </div>
                <form asp-action="ExportarPdf" asp-controller="Relatorios" method="get" target="_blank">
                    <div class="mb-3">
                        <label class="form-label">Selecione o mês</label>
                        <input type="month" name="mes" value="@ViewBag.MesAtual" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-danger fw-semibold w-100">
                        <i class="bi bi-download me-2"></i>Exportar PDF
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Placeholder para futuros relatórios -->
    <div class="col-12 col-md-6">
        <div class="card border-0 shadow-sm h-100 border-dashed">
            <div class="card-body d-flex align-items-center justify-content-center text-center">
                <div>
                    <i class="bi bi-graph-up text-muted fs-1 mb-3 d-block"></i>
                    <h6 class="text-muted">Mais relatórios em breve</h6>
                    <small class="text-muted">Relatório por categoria, comparativo mensal e outros.</small>
                </div>
            </div>
        </div>
    </div>
</div>
