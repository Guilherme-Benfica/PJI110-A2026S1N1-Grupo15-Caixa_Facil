@model LancamentoRecorrente
@{ ViewData["Title"] = "Editar lançamento recorrente"; }

<div class="row justify-content-center">
<div class="col-12 col-md-7">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 pt-3 fw-semibold">
            <i class="bi bi-pencil me-2 text-primary"></i>Editar lançamento recorrente
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-controller="Recorrentes" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                @await Html.PartialAsync("_RecorrenteForm", Model)
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary fw-semibold">
                        <i class="bi bi-floppy me-2"></i>Atualizar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
</div>
