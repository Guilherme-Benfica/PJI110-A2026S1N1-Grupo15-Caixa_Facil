@model LancamentoRecorrente

<div class="row g-3">
    <div class="col-6">
        <label asp-for="Tipo" class="form-label">Tipo <span class="text-danger">*</span></label>
        <select asp-for="Tipo" class="form-select">
            <option value="Entrada">🟢 Entrada</option>
            <option value="Saída">🔴 Saída</option>
        </select>
        <span asp-validation-for="Tipo" class="text-danger small"></span>
    </div>

    <div class="col-6">
        <label asp-for="DiaVencimento" class="form-label">Dia do mês <span class="text-danger">*</span></label>
        <input asp-for="DiaVencimento" type="number" min="1" max="28" class="form-control" placeholder="Ex: 5" />
        <span asp-validation-for="DiaVencimento" class="text-danger small"></span>
        <div class="form-text">Dia em que o lançamento será gerado todo mês (1 a 28).</div>
    </div>

    <div class="col-6">
        <label asp-for="Valor" class="form-label">Valor (R$) <span class="text-danger">*</span></label>
        <input asp-for="Valor" type="number" step="0.01" min="0.01" class="form-control" placeholder="0,00" />
        <span asp-validation-for="Valor" class="text-danger small"></span>
    </div>

    <div class="col-6">
        <label asp-for="CategoriaId" class="form-label">Categoria <span class="text-danger">*</span></label>
        <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" class="form-select">
            <option value="">Selecione...</option>
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger small"></span>
    </div>

    <div class="col-6">
        <label asp-for="ContaId" class="form-label">Conta / Caixa <span class="text-danger">*</span></label>
        <select asp-for="ContaId" asp-items="ViewBag.Contas" class="form-select">
            <option value="">Selecione...</option>
        </select>
        <span asp-validation-for="ContaId" class="text-danger small"></span>
    </div>

    <div class="col-6">
        <label asp-for="TipoMovimentoId" class="form-label">Forma de pagamento <span class="text-danger">*</span></label>
        <select asp-for="TipoMovimentoId" asp-items="ViewBag.TiposMovimento" class="form-select">
            <option value="">Selecione...</option>
        </select>
        <span asp-validation-for="TipoMovimentoId" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="Descricao" class="form-label">Descrição <span class="text-danger">*</span></label>
        <input asp-for="Descricao" class="form-control" placeholder="Ex: Aluguel, Internet, Energia..." maxlength="500" />
        <span asp-validation-for="Descricao" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <div class="form-check form-switch">
            <input asp-for="Ativo" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="Ativo" class="form-check-label">Recorrente ativo</label>
        </div>
    </div>
</div>
