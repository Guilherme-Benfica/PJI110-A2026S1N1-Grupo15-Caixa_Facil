<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="light" id="htmlRoot">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")CaixaFácil</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg shadow-sm" id="mainNavbar">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">
            <i class="bi bi-cash-coin me-1 text-success"></i> CaixaFácil
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>Painel
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Lancamentos" asp-action="Index">
                            <i class="bi bi-journal-text me-1"></i>Lançamentos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Recorrentes" asp-action="Index">
                            <i class="bi bi-arrow-repeat me-1"></i>Recorrentes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Relatorios" asp-action="Index">
                            <i class="bi bi-file-earmark-pdf me-1"></i>Relatórios
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-gear me-1"></i>Cadastros
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Categorias" asp-action="Index"><i class="bi bi-tags me-2"></i>Categorias</a></li>
                            <li><a class="dropdown-item" asp-controller="Contas" asp-action="Index"><i class="bi bi-wallet2 me-2"></i>Contas / Caixas</a></li>
                            <li><a class="dropdown-item" asp-controller="TiposMovimento" asp-action="Index"><i class="bi bi-card-list me-2"></i>Tipos de Movimento</a></li>
                        </ul>
                    </li>
                }
            </ul>

            <ul class="navbar-nav align-items-center">
                <li class="nav-item me-2">
                    <button id="btnTema" class="btn btn-outline-secondary btn-sm" title="Alternar tema">
                        <i class="bi bi-moon-stars-fill" id="icTema"></i>
                    </button>
                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person-gear me-2"></i>Perfil</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sair
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Entrar</a></li>
                    <li class="nav-item"><a class="btn btn-success btn-sm ms-2" asp-controller="Account" asp-action="Register">Criar conta</a></li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container-fluid py-4">
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</main>

<footer class="text-center py-3 small text-muted border-top mt-4">
    CaixaFácil &copy; @DateTime.Now.Year — Controle financeiro para pequenos negócios
</footer>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="~/js/theme.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
