@model TipoMovimento
@{ ViewData["Title"] = "Editar tipo"; }
<div class="row justify-content-center"><div class="col-12 col-md-4">
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0 pt-3 fw-semibold"><i class="bi bi-pencil me-2 text-primary"></i>Editar tipo de movimento</div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3"><label asp-for="Nome" class="form-label">Nome <span class="text-danger">*</span></label><input asp-for="Nome" class="form-control" /><span asp-validation-for="Nome" class="text-danger small"></span></div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary">Atualizar</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
        </form>
    </div>
</div></div></div>
