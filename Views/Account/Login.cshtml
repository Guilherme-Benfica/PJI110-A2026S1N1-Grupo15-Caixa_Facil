@model LoginViewModel
@{ ViewData["Title"] = "Entrar"; Layout = null; }
<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="light" id="htmlRoot">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>CaixaFácil — Entrar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 bg-body-secondary">
<div class="card shadow border-0" style="width:380px">
    <div class="card-body p-4">
        <div class="text-center mb-4">
            <i class="bi bi-cash-coin text-success fs-1"></i>
            <h4 class="fw-bold mt-2">CaixaFácil</h4>
            <p class="text-muted small">Controle financeiro para pequenos negócios</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@e.ErrorMessage</div> }
            </div>
        }

        <form asp-action="Login" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="mb-3">
                <label asp-for="Email" class="form-label">E-mail</label>
                <input asp-for="Email" class="form-control" placeholder="seu@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Senha" class="form-label">Senha</label>
                <input asp-for="Senha" class="form-control" placeholder="••••••" autocomplete="current-password" />
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success w-100 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
            </button>
        </form>

        <hr class="my-3" />
        <p class="text-center mb-0 small">
            Não tem conta? <a asp-controller="Account" asp-action="Register">Criar agora</a>
        </p>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/theme.js"></script>
</body>
</html>
