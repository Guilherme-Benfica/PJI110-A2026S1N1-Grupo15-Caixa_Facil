@model DashboardViewModel
@{ ViewData["Title"] = "Painel"; }

<div class="row g-4 mb-4">
    <!-- Entradas -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100 card-entrada">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="icon-box bg-success-subtle rounded-3 p-3">
                    <i class="bi bi-arrow-down-circle-fill text-success fs-3"></i>
                </div>
                <div>
                    <p class="text-muted mb-0 small">Entradas — @Model.MesAno</p>
                    <h4 class="fw-bold text-success mb-0">R$ @Model.TotalEntradas.ToString("N2")</h4>
                </div>
            </div>
        </div>
    </div>
    <!-- Saídas -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100 card-saida">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="icon-box bg-danger-subtle rounded-3 p-3">
                    <i class="bi bi-arrow-up-circle-fill text-danger fs-3"></i>
                </div>
                <div>
                    <p class="text-muted mb-0 small">Saídas — @Model.MesAno</p>
                    <h4 class="fw-bold text-danger mb-0">R$ @Model.TotalSaidas.ToString("N2")</h4>
                </div>
            </div>
        </div>
    </div>
    <!-- Saldo -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100 @(Model.Saldo >= 0 ? "card-positivo" : "card-negativo")">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="icon-box @(Model.Saldo >= 0 ? "bg-primary-subtle" : "bg-warning-subtle") rounded-3 p-3">
                    <i class="bi bi-wallet2 @(Model.Saldo >= 0 ? "text-primary" : "text-warning") fs-3"></i>
                </div>
                <div>
                    <p class="text-muted mb-0 small">Saldo — @Model.MesAno</p>
                    <h4 class="fw-bold @(Model.Saldo >= 0 ? "text-primary" : "text-warning") mb-0">R$ @Model.Saldo.ToString("N2")</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gráfico + tabela -->
<div class="row g-4">
    <div class="col-12 col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header fw-semibold bg-transparent border-0 pt-3">
                <i class="bi bi-bar-chart-fill me-2 text-primary"></i>Movimentos — últimos 7 dias
            </div>
            <div class="card-body">
                <canvas id="graficoMovimentos" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header fw-semibold bg-transparent border-0 pt-3 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-list-ul me-2 text-primary"></i>Últimos lançamentos</span>
                <a asp-controller="Lancamentos" asp-action="Create" class="btn btn-success btn-sm">
                    <i class="bi bi-plus-lg me-1"></i>Novo
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.UltimosLancamentos.Any())
                {
                    <p class="text-muted p-3 mb-0">Nenhum lançamento este mês.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Data</th>
                                    <th>Tipo</th>
                                    <th>Categoria</th>
                                    <th class="text-end">Valor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in Model.UltimosLancamentos)
                                {
                                    <tr>
                                        <td>@l.Data.ToString("dd/MM")</td>
                                        <td>
                                            <span class="badge @(l.Tipo == "Entrada" ? "bg-success" : "bg-danger")">@l.Tipo</span>
                                        </td>
                                        <td>@(l.Categoria?.Nome ?? "—")</td>
                                        <td class="text-end fw-semibold @(l.Tipo == "Entrada" ? "text-success" : "text-danger")">
                                            R$ @l.Valor.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="card-footer text-end bg-transparent border-0 pb-3">
                <a asp-controller="Lancamentos" asp-action="Index" class="btn btn-outline-secondary btn-sm">Ver todos</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const labels   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoLabels));
    const entradas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoEntradas));
    const saidas   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoSaidas));

    new Chart(document.getElementById('graficoMovimentos'), {
        type: 'bar',
        data: {
            labels,
            datasets: [
                { label: 'Entradas', data: entradas, backgroundColor: 'rgba(25,135,84,0.7)', borderRadius: 4 },
                { label: 'Saídas',   data: saidas,   backgroundColor: 'rgba(220,53,69,0.7)', borderRadius: 4 }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'bottom' } },
            scales: { y: { beginAtZero: true, ticks: { callback: v => 'R$ ' + v.toFixed(2) } } }
        }
    });
})();
</script>
}
